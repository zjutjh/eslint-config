{
  "name": "@zjutjh/eslint-config",
  "version": "2.0.0-beta.1",
  "description": "ESLint config used by zjutjh",
  "license": "ISC",
  "author": "zjutjh",
  "repository": {
    "type": "git",
    "url": "https://github.com/zjutjh/eslint-config.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "dev": "config-inspector",
    "release": "bumpp && pnpm publish --access public",
    "prepublish": "pnpm build",
    "postinstall": "npx simple-git-hooks"
  },
  "dependencies": {
    "@antfu/install-pkg": "catalog:helper",
    "@clack/prompts": "catalog:helper",
    "@eslint/compat": "catalog:helper",
    "@eslint/js": "catalog:required",
    "eslint-plugin-format": "catalog:required",
    "eslint-plugin-import-x": "catalog:required",
    "eslint-plugin-simple-import-sort": "catalog:required",
    "eslint-plugin-unicorn": "catalog:required",
    "globals": "catalog:helper",
    "local-pkg": "catalog:helper",
    "oxfmt": "catalog:required"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "catalog:optional",
    "@eslint/config-inspector": "catalog:dev",
    "@eslint/core": "catalog:typing",
    "@types/node": "catalog:typing",
    "@typescript-eslint/eslint-plugin": "catalog:optional",
    "@typescript-eslint/parser": "catalog:optional",
    "bumpp": "catalog:infra",
    "cspell": "catalog:infra",
    "eslint": "catalog:binary",
    "eslint-plugin-react-hooks": "catalog:optional",
    "eslint-plugin-react-refresh": "catalog:optional",
    "eslint-plugin-vue": "catalog:optional",
    "lint-staged": "catalog:binary",
    "simple-git-hooks": "catalog:infra",
    "tsdown": "catalog:infra",
    "typescript": "catalog:infra",
    "vue-eslint-parser": "catalog:optional"
  },
  "peerDependencies": {
    "@eslint-react/eslint-plugin": "catalog:optional",
    "@typescript-eslint/eslint-plugin": "catalog:optional",
    "@typescript-eslint/parser": "catalog:optional",
    "eslint": "catalog:binary",
    "eslint-plugin-react-hooks": "catalog:optional",
    "eslint-plugin-react-refresh": "catalog:optional",
    "eslint-plugin-vue": "catalog:optional",
    "vue-eslint-parser": "catalog:optional"
  },
  "peerDependenciesMeta": {
    "@eslint-react/eslint-plugin": {
      "optional": true
    },
    "@typescript-eslint/eslint-plugin": {
      "optional": true
    },
    "@typescript-eslint/parser": {
      "optional": true
    },
    "eslint-plugin-react-hooks": {
      "optional": true
    },
    "eslint-plugin-react-refresh": {
      "optional": true
    },
    "eslint-plugin-vue": {
      "optional": true
    },
    "vue-eslint-parser": {
      "optional": true
    }
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.0"
}
